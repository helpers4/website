---
/**
 * This file is part of helpers4.
 * Copyright (C) 2025 baxyz
 * SPDX-License-Identifier: LGPL-3.0-or-later
 *
 * Per-product version switcher, inspired by starlight-versions' VersionSelect
 * (https://github.com/HiDeoo/starlight-versions, MIT) but scoped to a single
 * product/topic and driven by ../data/versions.json instead of a global,
 * whole-site version collection — starlight-versions archives the entire
 * src/content/docs/ tree on every cut, which doesn't fit three independently
 * released products sharing one site (see helpers4/website#version-handling).
 */
import versions from '../data/versions.json';

type VersionEntry = { slug: string; label: string; role: 'next' | 'latest' | 'archive' };

const segments = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/');
const product = segments[0] as keyof typeof versions;
const entries = (versions[product] ?? []) as VersionEntry[];

// Longest-prefix match so `typescript/v2/...` resolves before the bare `typescript` root.
const currentSlug = [...entries]
	.sort((a, b) => b.slug.length - a.slug.length)
	.find((v) => Astro.url.pathname === `/${v.slug}/` || Astro.url.pathname.startsWith(`/${v.slug}/`))?.slug;
---

{
	entries.length > 1 && (
		<starlight-version-select>
			<label>
				<span class="sr-only">Choose a version</span>
				<select autocomplete="off">
					{entries.map((v) => (
						<option value={`/${v.slug}/`} selected={v.slug === currentSlug}>
							{v.label}
						</option>
					))}
				</select>
				<svg aria-hidden="true" class="caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</label>
		</starlight-version-select>
	)
}

<style>
	/* Sized/bordered to match starlight-theme-nova's ThemeSelect toggle button (size-8,
	   rounded-md, border) — this sits right next to it in the header, see
	   src/components/ThemeSelect.astro. */
	label {
		align-items: center;
		background-color: var(--sl-color-black);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		color: var(--sl-color-gray-2);
		display: flex;
		height: 2rem;
		position: relative;
	}

	label:hover {
		border-color: var(--sl-color-gray-2);
		color: var(--sl-color-white);
	}

	select {
		appearance: none;
		background-color: transparent;
		border: 0;
		color: inherit;
		cursor: pointer;
		font-size: var(--sl-text-xs);
		font-weight: 600;
		padding-block: 0;
		padding-inline: 0.625rem 1.375rem;
		height: 100%;
	}

	option {
		background-color: var(--sl-color-bg-nav);
		color: var(--sl-color-gray-1);
	}

	.caret {
		height: 0.875rem;
		width: 0.875rem;
		pointer-events: none;
		position: absolute;
		inset-inline-end: 0.375rem;
	}
</style>

<script>
	customElements.define(
		'starlight-version-select',
		class StarlightVersionSelect extends HTMLElement {
			constructor() {
				super();
				const select = this.querySelector('select');
				select?.addEventListener('change', (event) => {
					if (event.currentTarget instanceof HTMLSelectElement) {
						globalThis.location.pathname = event.currentTarget.value;
					}
				});
			}
		},
	);
</script>
