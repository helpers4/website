export interface ProjectCard {
  title: string;
  label: string;
  description: string;
  docsHref: string;
  repoPath: string;
}

interface Props {
  card: ProjectCard;
  stars: number | null;
}

const { card, stars } = Astro.props;

function formatStars(value: number | null): string {
  if (value === null) return '–';
  if (value >= 1000) return `${(value / 1000).toFixed(1)}k`;
  return String(value);
}
---

<div class="project-card">
  <div class="card-header">
    <h3>{card.title}</h3>
    <a
      href={`https://github.com/${card.repoPath}`}
      class="stars-badge"
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${formatStars(stars)} stars on GitHub`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      {formatStars(stars)}
    </a>
  </div>

  <p class="card-description">{card.description}</p>

  <div class="card-footer">
    <a href={card.docsHref} class="btn btn-primary">
      Open {card.label} docs
    </a>
    <a
      href={`https://github.com/${card.repoPath}`}
      class="btn btn-outline"
      target="_blank"
      rel="noopener noreferrer"
    >
      GitHub
    </a>
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-bg-nav);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .project-card:hover {
    border-color: var(--sl-color-accent);
    box-shadow: 0 2px 16px color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-text-accent);
  }

  .stars-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5);
    transition: color 0.2s;
  }

  .stars-badge:hover {
    color: var(--sl-color-text-accent);
  }

  .card-description {
    margin: 0;
    font-size: 0.95rem;
    color: var(--sl-color-gray-2);
    flex: 1;
  }

  .card-footer {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .btn-primary {
    background: var(--sl-color-accent);
    color: #fff;
    border: 1px solid transparent;
  }

  .btn-primary:hover {
    background: var(--sl-color-accent-high);
  }

  .btn-outline {
    background: transparent;
    color: var(--sl-color-text);
    border: 1px solid var(--sl-color-gray-4);
  }

  .btn-outline:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
</style>
