 *
 * Re-renders starlight-sidebar-topics' own sidebar explicitly. starlight-sidebar-topics
 * registers this same override itself, but defers to a user-provided `components.Sidebar`
 * — see its `config:setup` hook, which spreads `starlightConfig.components` after its own
 * default — so this file replaces it wholesale.
 *
 * VersionSelect lives in the header (see ThemeSelect.astro), not here — matching where
 * starlight-versions itself puts it, next to the theme toggle, always visible instead of
 * buried in a collapsible sidebar section.
 */
import Default from '@astrojs/starlight/components/Sidebar.astro';
import TopicsSidebar from 'starlight-sidebar-topics/components/Sidebar.astro';
---

<TopicsSidebar />
<Default><slot /></Default>
