 *
 * Re-renders the topics switcher explicitly instead of using starlight-sidebar-topics' own
 * Sidebar override — see TopicsSwitcher.astro for why (dedup topics sharing a label). Registered
 * as the Starlight `Sidebar` override in astro.config.mjs; the plugin defers to a user-provided
 * `components.Sidebar` (spreads `starlightConfig.components` after its own default in its
 * `config:setup` hook), so this file replaces it wholesale.
 */
import Default from '@astrojs/starlight/components/Sidebar.astro';
import TopicsSwitcher from './TopicsSwitcher.astro';
---

<TopicsSwitcher />
<Default><slot /></Default>
