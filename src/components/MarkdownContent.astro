import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import type { Props } from '@astrojs/starlight/props';
import { TOPICS } from '../lib/topics';

const slug: string = (Astro.props as Props).slug ?? '';
const topic = TOPICS.find((t) => slug === t || slug.startsWith(t + '/'));
---

{topic && <span data-pagefind-filter={`topic:${topic}`} style="display:none" />}
<Default {...(Astro.props as Props)}><slot /></Default>
