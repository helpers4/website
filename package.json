{
  "name": "@helpers4/website",
  "version": "1.0.0",
  "description": "helpers4 unified website: landing page + documentation",
  "license": "LGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/helpers4/website"
  },
  "private": true,
  "engines": {
    "pnpm": ">=9.0.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "install-all": "pnpm install",
    "build:landing": "pnpm --filter landing build",
    "build:docs:typescript": "pnpm --filter ./docs/typescript build",
    "build:docs:devcontainer": "pnpm --filter ./docs/devcontainer build",
    "build:docs:action": "pnpm --filter ./docs/github-action build",
    "build:all": "pnpm build:landing && sh ./merge-builds.sh",
    "merge-builds": "sh ./merge-builds.sh",
    "build": "pnpm build:all",
    "dev:landing": "pnpm --filter landing dev",
    "dev:docs:typescript": "pnpm --filter ./docs/typescript start",
    "dev:docs:devcontainer": "pnpm --filter ./docs/devcontainer start",
    "dev:docs:action": "pnpm --filter ./docs/github-action start",
    "generate-docs:typescript": "node scripts/generate-typescript-docs.js",
    "generate-docs:devcontainer": "node scripts/generate-devcontainer-docs.js",
    "generate-docs:action": "node scripts/generate-action-docs.js",
    "sync-from-repos": "node scripts/sync-from-repos.js",
    "clean": "pnpm --filter landing clean && pnpm --filter ./docs/typescript clean && pnpm --filter ./docs/devcontainer clean && pnpm --filter ./docs/github-action clean && rm -rf dist build coverage",
    "reset-hard": "git clean -dfx && git reset --hard && pnpm install"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
